generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  superadmin
}

enum PropertyType {
  ruko
  villa
}

enum PropertyStatus {
  in_stock
  sold_out
}

enum PropertyReady {
  siap_huni
  siap_kosong
  siap_huni_renovasi
}

model User {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(100)
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  role             UserRole
  isActive         Boolean   @default(true) @map("is_active")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockoutUntil     DateTime? @map("lockout_until")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        String?   @map("created_by")
  sessions         Session[]
  createdProperties Property[] @relation("PropertyCreatedBy")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@map("sessions")
}

model Property {
  id           String         @id @default(cuid())
  namaProperty String         @map("nama_property") @db.VarChar(100)
  group        String?        @db.VarChar(100)
  lebar        Decimal        @db.Decimal(5, 2)
  panjang      Decimal        @db.Decimal(5, 2)
  hadap        String[]
  tipe         PropertyType
  tingkat      Decimal        @db.Decimal(3, 1)
  price        BigInt
  carport      Boolean
  status       PropertyStatus
  siap         PropertyReady
  mapsLink     String?        @map("maps_link")
  isFeatured   Boolean        @map("is_featured") @default(false)
  kawasan      String[]
  gallery      String[]       @default([])
  unit         String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  createdById  String         @map("created_by")
  createdBy    User           @relation("PropertyCreatedBy", fields: [createdById], references: [id])
  deletedAt    DateTime?      @map("deleted_at")

  @@index([status, tipe, price, deletedAt])
  @@index([isFeatured, deletedAt])
  @@map("properties")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String   @map("user_id")
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(50)
  changes    Json
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}
